# Copy this file to `.env` and fill in your Supabase project values.
# Find them in the Supabase dashboard: Project Settings -> API.
# Only the ANON (public) key goes here — never the service_role key.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: force demo mode (sample data, no backend). You normally don't need
# this — just append ?demo to the URL to preview the app with sample data.
# VITE_DEMO=1

# Optional: production error monitoring (Sentry). Leave unset to disable — the
# app works without it and Sentry is only loaded when a DSN is present. For
# GitHub Pages, add this as a VITE_SENTRY_DSN repository secret and pass it to
# the build step, the same way as the Supabase keys.
# VITE_SENTRY_DSN=https://exampledsn@o0.ingest.sentry.io/0
